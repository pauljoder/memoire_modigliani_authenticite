s[[\"name\", \"paintings\"]].to_string())"],"metadata":{"id":"eSGs5CqY1xXU","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1782146819679,"user_tz":-120,"elapsed":39,"user":{"displayName":"Paul","userId":"11959497790999990879"}},"outputId":"3e9c225b-2eb2-40f0-8190-fc130bd773e1"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["Colonnes disponibles : ['id', 'name', 'years', 'genre', 'nationality', 'bio', 'wikipedia', 'paintings']\n","Nombre d'artistes : 50\n","\n","                         name  paintings\n","0           Amedeo Modigliani        193\n","1          Vasiliy Kandinskiy         88\n","2                Diego Rivera         70\n","3                Claude Monet         73\n","4               Rene Magritte        194\n","5               Salvador Dali        139\n","6               Edouard Manet         90\n","7               Andrei Rublev         99\n","8            Vincent van Gogh        877\n","9                Gustav Klimt        117\n","10           Hieronymus Bosch        137\n","11           Kazimir Malevich        126\n","12             Mikhail Vrubel        171\n","13              Pablo Picasso        439\n","14          Peter Paul Rubens        141\n","15      Pierre-Auguste Renoir        336\n","16             Francisco Goya        291\n","17                Frida Kahlo        120\n","18                   El Greco         87\n","19             Albrecht Dürer        328\n","20              Alfred Sisley        259\n","21             Pieter Bruegel        134\n","22               Marc Chagall        239\n","23          Giotto di Bondone        119\n","24          Sandro Botticelli        164\n","25                 Caravaggio         55\n","26          Leonardo da Vinci        143\n","27            Diego Velazquez        128\n","28              Henri Matisse        186\n","29               Jan van Eyck         81\n","30                Edgar Degas        702\n","31                